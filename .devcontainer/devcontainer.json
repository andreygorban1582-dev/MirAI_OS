{
  "name": "MirAI_OS",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "bash install.sh",
  "forwardPorts": [11434],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "remoteEnv": {
    "USE_OLLAMA": "true",
    "OLLAMA_MODEL": "dolphin-mistral"
  }
}
