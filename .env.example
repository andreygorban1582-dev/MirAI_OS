# MirAI_OS Environment Configuration
# Copy to .env and fill in your values.
# Never commit .env to git.

# ── LLM / Ollama ──────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=dolphin-llama3:8b

# ── OpenRouter fallback (optional) ────────────────────────────────────────
OPENROUTER_API_KEY=

# ── Telegram bot (optional) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# ── Feature flags ─────────────────────────────────────────────────────────
WSL_ENABLED=true
KALI_ENABLED=true
VOICE_ENABLED=false
LOG_LEVEL=INFO
