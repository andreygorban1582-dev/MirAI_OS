# MirAI_OS Environment Configuration
# Copy this file to .env and fill in your values.
# The installer (install.sh) will do this automatically.

# ── LLM ───────────────────────────────────────────────────────
# Ollama model to use (pulled automatically by the installer)
# Good options: dolphin-mistral, llama3:8b, mistral, phi3:mini
OLLAMA_MODEL=dolphin-mistral

# OpenRouter API key (fallback when Ollama is unavailable)
# Get one free at https://openrouter.ai/
OPENROUTER_API_KEY=

# ── Telegram Bot ──────────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get a token
TELEGRAM_TOKEN=

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=mirai
POSTGRES_USER=mirai
POSTGRES_PASSWORD=mirai_secret

# ── N8n automation ────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=mirai_n8n

# ── Flowise visual builder ────────────────────────────────────
FLOWISE_USER=admin
FLOWISE_PASSWORD=mirai_flowise

# ── Security ──────────────────────────────────────────────────
# Change this to a long random string in production!
SECRET_KEY=change_this_in_production
