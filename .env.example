# ═══════════════════════════════════════════════════════════════════
#  MirAI_OS  –  Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── OpenRouter (LLM Engine) ──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-4o              # any model slug from openrouter.ai
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Telegram Bot ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAABBBCCC-xxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_ALLOWED_USERS=123456789,987654321  # Comma-separated user IDs (leave blank for public)

# ── GitHub (self-modification / Copilot access) ──────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=andreygorban1582-dev/MirAI_OS
GITHUB_BRANCH=main

# ── Tor / Anonymity ───────────────────────────────────────────────
TOR_ENABLED=true
TOR_CONTROL_PORT=9051
TOR_SOCKS_PORT=9050
TOR_PASSWORD=                               # Leave blank if no password set

# ── Voice I/O ────────────────────────────────────────────────────
VOICE_ENABLED=false                         # Set true to enable mic/speaker
VOICE_TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
VOICE_LANGUAGE=en

# ── SSH Codespace Connector ───────────────────────────────────────
SSH_HOST=
SSH_USER=
SSH_KEY_PATH=~/.ssh/id_rsa
SSH_PORT=22

# ── General ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=./data
