# MirAI_OS environment variables
# Copy this file to .env and fill in your values.

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# ── LLM ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=dolphin-mistral

# ── Voice ─────────────────────────────────────────────────────
VOICE_ENABLED=false
VOICE_LANG=en-US
TTS_ENGINE=pyttsx3

# ── SSH / Codespace ───────────────────────────────────────────
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_KEY_PATH=~/.ssh/id_rsa

# ── Mod 2 ─────────────────────────────────────────────────────
MOD2_ENABLED=true
MOD2_MEMORY_PATH=data/memory.json
MOD2_MAX_MEMORY=1000
MOD2_WEB_SEARCH=true

# ── Agent ─────────────────────────────────────────────────────
AGENT_MAX_STEPS=10
AGENT_TIMEOUT=60

# ── Kali ──────────────────────────────────────────────────────
KALI_ENABLED=false

# ── App ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
