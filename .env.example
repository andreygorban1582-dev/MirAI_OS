# ═══════════════════════════════════════════════════════════════════════════════
#  MirAI_OS  –  Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── LLM / Ollama ─────────────────────────────────────────────────────────────
OLLAMA_MODEL=nous-hermes-2-mistral-7b-dpo
# Alternative: dolphin-mistral, mistral, llama3, phi3

# ─── OpenRouter (optional cloud LLM fallback) ─────────────────────────────────
OPENROUTER_API_KEY=

# ─── Telegram Bot (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Database ─────────────────────────────────────────────────────────────────
DB_USER=mirai
DB_PASSWORD=mirai_db_pass_change_me

# ─── Redis / ChromaDB ─────────────────────────────────────────────────────────
CHROMA_TOKEN=mirai_chroma_token_change_me

# ─── N8n ──────────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=mirai_n8n_pass_change_me
N8N_ENCRYPTION_KEY=mirai_n8n_enc_key_change_me

# ─── Flowise ──────────────────────────────────────────────────────────────────
FLOWISE_USER=admin
FLOWISE_PASSWORD=mirai_flowise_pass_change_me

# ─── Agentverse ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=mirai_secret_change_me

# ─── Rancher ──────────────────────────────────────────────────────────────────
RANCHER_BOOTSTRAP_PASSWORD=mirai_rancher_pass_change_me
SSH_KEY_PATH=~/.ssh

# ─── MinIO D-Drive Storage ────────────────────────────────────────────────────
MINIO_USER=mirai_admin
MINIO_PASSWORD=mirai_minio_pass_change_me
# Path to D: drive in WSL2  (Windows: D:\mirai_storage)
D_DRIVE_PATH=/mnt/d/mirai_storage

# ─── Swap Manager ─────────────────────────────────────────────────────────────
SWAP_SIZE_GB=256
SWAP_PATH=/mnt/d/mirai_swap

# ─── Kali VNC ─────────────────────────────────────────────────────────────────
VNC_PASSWORD=mirai_vnc_change_me
