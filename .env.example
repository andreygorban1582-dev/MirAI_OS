# MirAI_OS Configuration
# Copy this file to .env and fill in your values

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=mistralai/mistral-7b-instruct

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# HuggingFace (for Sesame CSM / voice models)
HUGGINGFACE_TOKEN=your_hf_token_here

# Hardware Profile
HARDWARE_PROFILE=legion_go
# Options: legion_go, generic, high_end, low_end

# Legion Go specific settings
LEGION_GO_ENABLED=true
AMD_ROCM_ENABLED=true
ROCM_HOME=/opt/rocm

# Performance
MAX_CONTEXT_TOKENS=4096
GPU_LAYERS=20
CPU_THREADS=8
QUANTIZATION=Q4_K_M

# Voice I/O
VOICE_ENABLED=true
VOICE_SAMPLE_RATE=22050
VOICE_LANGUAGE=en

# Lab
LAB_ENABLED=true
LAB_PORT=7860

# Kali Linux Integration
KALI_SSH_HOST=
KALI_SSH_USER=
KALI_SSH_KEY_PATH=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/mirai.log

# Codespace SSH
CODESPACE_SSH_HOST=
CODESPACE_SSH_USER=
CODESPACE_SSH_KEY=
