# ============================================================
#  MirAI OS — Environment Variables
#  Copy to .env and fill in your values
#  NEVER commit .env to git!
# ============================================================

# ── OpenRouter API Keys (4 keys for rotation) ──────────────
OPENROUTER_KEY_1=sk-or-v1-REPLACE_KEY_1
OPENROUTER_KEY_2=sk-or-v1-REPLACE_KEY_2
OPENROUTER_KEY_3=sk-or-v1-REPLACE_KEY_3
OPENROUTER_KEY_4=sk-or-v1-REPLACE_KEY_4

# ── Telegram Bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_ADMIN_IDS=123456789,987654321   # comma-separated Telegram user IDs

# ── GitHub (for self-modification) ─────────────────────────
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN
GITHUB_REPO=YOUR_USERNAME/MirAI_OS

# ── Redis (optional, defaults to localhost) ─────────────────
REDIS_URL=redis://localhost:6379/0

# ── Encryption key for keystore ─────────────────────────────
MIRAI_SECRET_KEY=GENERATE_WITH_python_-c_"import_secrets;print(secrets.token_hex(32))"

# ── Optional: Claude API (only for assisted development) ────
# ANTHROPIC_API_KEY=sk-ant-REPLACE_IF_USED

# ── Additional API keys (added dynamically by MirAI) ────────
# MirAI will append new keys here as you give them
