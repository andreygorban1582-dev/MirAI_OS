# ============================================================
#  MirAI OS — Environment Variables
#  Copy to .env and fill in your values
#  NEVER commit .env to git!
# ============================================================

# ── OpenRouter API Keys (4 keys for rotation) ──────────────
OPENROUTER_KEY_1=sk-or-v1-REPLACE_KEY_1
OPENROUTER_KEY_2=sk-or-v1-REPLACE_KEY_2
OPENROUTER_KEY_3=sk-or-v1-REPLACE_KEY_3
OPENROUTER_KEY_4=sk-or-v1-REPLACE_KEY_4

# ── Telegram Bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_ADMIN_IDS=123456789,987654321   # comma-separated Telegram user IDs

# ── GitHub (for self-modification) ─────────────────────────
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN
GITHUB_REPO=YOUR_USERNAME/MirAI_OS

# ── Redis (optional, defaults to localhost) ─────────────────
REDIS_URL=redis://localhost:6379/0

# ── Encryption key for keystore ─────────────────────────────
MIRAI_SECRET_KEY=GENERATE_WITH_python_-c_"import_secrets;print(secrets.token_hex(32))"

# ══════════════════════════════════════════════════════════════
# ── OPTIONAL INTEGRATIONS (add keys to enable) ────────────────
# ══════════════════════════════════════════════════════════════

# ── Groq (FASTEST free LLM — Llama 3.1 70B) ─────────────────
# Signup: https://console.groq.com | Free: 14,400 req/day
# Also set integrations.groq.enabled: true in settings.yaml
# GROQ_API_KEY=gsk_REPLACE_WITH_GROQ_KEY

# ── Together.ai (Large models — Qwen 72B, Llama 70B) ─────────
# Signup: https://api.together.xyz | Free: $1 credit on signup
# Also set integrations.together.enabled: true in settings.yaml
# TOGETHER_API_KEY=REPLACE_WITH_TOGETHER_KEY

# ── NotDiamond (Auto-route to best LLM per query) ────────────
# Signup: https://app.notdiamond.ai | Free tier available
# Also set integrations.notdiamond.enabled: true in settings.yaml
# NOTDIAMOND_API_KEY=REPLACE_WITH_NOTDIAMOND_KEY

# ── Tavily (AI-optimized web search) ─────────────────────────
# Signup: https://tavily.com | Free: 1,000 searches/month
# Also set integrations.tavily.enabled: true in settings.yaml
# TAVILY_API_KEY=tvly-REPLACE_WITH_TAVILY_KEY

# ── Mem0 (Cloud memory — persists across reinstalls) ─────────
# Signup: https://mem0.ai | Free tier available
# Also set integrations.mem0.enabled: true in settings.yaml
# MEM0_API_KEY=REPLACE_WITH_MEM0_KEY

# ── Qdrant Cloud (Managed vector store — scales beyond local) ─
# Signup: https://cloud.qdrant.io | Free: 1GB
# Also set integrations.qdrant.enabled: true in settings.yaml
# QDRANT_URL=https://YOUR-CLUSTER.aws.cloud.qdrant.io
# QDRANT_API_KEY=REPLACE_WITH_QDRANT_KEY

# ── Cloudflare Tunnel (Public internet access — no port forward)
# Option A: Quick tunnel (no account, temporary URL)
#   Set integrations.cloudflare_tunnel.quick_tunnel: true
# Option B: Named tunnel (permanent URL, needs Cloudflare account)
# Dashboard: https://one.dash.cloudflare.com | Free
# CLOUDFLARE_TUNNEL_TOKEN=REPLACE_WITH_CF_TUNNEL_TOKEN

# ── Ngrok (Alternative tunnel — instant public URL) ───────────
# Signup: https://ngrok.com | Free: 1 tunnel, random URL
# Also set integrations.ngrok.enabled: true in settings.yaml
# NGROK_AUTH_TOKEN=REPLACE_WITH_NGROK_TOKEN
# NGROK_DOMAIN=                              # Paid: static domain

# ── Internal API port (for tunnel endpoints) ──────────────────
MIRAI_API_PORT=8080

# ── Additional API keys (added dynamically by MirAI) ──────────
# MirAI will append new keys here as you give them via Telegram
